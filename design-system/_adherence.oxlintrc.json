{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/patterns/**",
              "ui_kits/desktop/**",
              "ui_kits/mobile/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Inter|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Geist, Inter, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|tone|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|cyan|violet|slate)$/]",
        "message": "<Avatar> tone must be one of 'blue' | 'cyan' | 'violet' | 'slate'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|style|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|disabled|type|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, disabled, type, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|hover|padding|as|style|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, hover, padding, as, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|flat|tinted)$/]",
        "message": "<Card> variant must be one of 'default' | 'flat' | 'tinted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|strokeWidth|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, strokeWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|size|radius|style|children|key|ref|className|style|children)$/]",
        "message": "<IconChip> doesn't accept that prop. Declared props: tone, size, radius, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconChip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|cyan|violet|green|amber|rose)$/]",
        "message": "<IconChip> tone must be one of 'blue' | 'cyan' | 'violet' | 'green' | 'amber' | 'rose'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KPICard'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|tone|delta|deltaDir|style|key|ref|className|style|children)$/]",
        "message": "<KPICard> doesn't accept that prop. Declared props: value, label, icon, tone, delta, deltaDir, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KPICard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|cyan|violet|green|amber|rose)$/]",
        "message": "<KPICard> tone must be one of 'blue' | 'cyan' | 'violet' | 'green' | 'amber' | 'rose'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KPICard'] > JSXAttribute[name.name='deltaDir'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<KPICard> deltaDir must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:leading|title|subtitle|trailing|divider|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ListRow> doesn't accept that prop. Declared props: leading, title, subtitle, trailing, divider, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|minWidth|style|children|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: tone, dot, minWidth, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|tone|height|label|showPct|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, tone, height, label, showPct, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|cyan|violet|green|amber|rose)$/]",
        "message": "<ProgressBar> tone must be one of 'blue' | 'cyan' | 'violet' | 'green' | 'amber' | 'rose'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StageStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|title|caption|state|tone|last|style|key|ref|className|style|children)$/]",
        "message": "<StageStep> doesn't accept that prop. Declared props: index, title, caption, state, tone, last, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StageStep'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:done|active|todo)$/]",
        "message": "<StageStep> state must be one of 'done' | 'active' | 'todo'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StageStep'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|cyan|violet|green|amber|rose)$/]",
        "message": "<StageStep> tone must be one of 'blue' | 'cyan' | 'violet' | 'green' | 'amber' | 'rose'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
